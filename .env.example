# ── Turso database ────────────────────────────────────────────────────────────
# Get these from: https://app.turso.tech → your database → Connect
TURSO_DATABASE_URL=libsql://your-db-name-your-username.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Auth ──────────────────────────────────────────────────────────────────────
# AUTH_PASSWORD  = the password you'll type to log in
# AUTH_SECRET    = a random 32-char string (acts as the session token)
#                  generate one at: https://generate-secret.vercel.app/32
AUTH_PASSWORD=choose-a-strong-password
AUTH_SECRET=paste-a-random-32-character-string-here
