{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Life Dashboard",
  "version": "0.1.0",
  "identifier": "com.personal.life-dashboard",
  "build": {
    "frontendDist": "./dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Life Dashboard",
        "url": "http://localhost:3000",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {},
    "resources": {
      "target/release/server": "server"
    }
  }
}
